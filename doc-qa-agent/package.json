{
  "name": "doc-qa-agent",
  "version": "0.1.0",
  "description": "CLI agent to validate documentation examples against OpenAPI specs",
  "main": "dist/cli.js",
  "type": "module",
  "scripts": {
    "build": "tsc",
    "start": "node dist/cli.js",
    "check": "node dist/cli.js check",
    "check-all": "node dist/cli.js check-all",
    "dev": "ts-node src/cli.ts",
    "test": "echo \"Error: no test specified\" && exit 1"
  },
  "keywords": [
    "documentation",
    "qa",
    "openapi",
    "validation"
  ],
  "author": "",
  "license": "Apache-2.0",
  "dependencies": {
    "@apidevtools/swagger-parser": "^10.1.0",
    "ajv": "^8.12.0",
    "commander": "^11.1.0",
    "js-yaml": "^4.1.0"
  },
  "devDependencies": {
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^20.10.6",
    "typescript": "^5.3.3",
    "ts-node": "^10.9.2"
  }
}
